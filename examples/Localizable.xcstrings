    "error_network": {
      "comment": "Shown when network request fails",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network error. Please check your connection and try again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Erreur réseau. Veuillez vérifier votre connexion et réessayer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de red. Por favor, comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Netzwerkfehler. Bitte überprüfe deine Verbindung und versuche es erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークエラーです。接続を確認して、もう一度お試しください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сетевая ошибка. Проверьте подключение и попробуйте снова."
          }
        }
      }
    },
