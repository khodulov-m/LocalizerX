    "This action cannot be undone. All your data will be permanently deleted.\n\nType DELETE to confirm.": {
      "comment": "An alert message displayed when a user attempts to delete their account. It explains that the action cannot be undone and asks the user to confirm by typing \"DELETE\".",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This action cannot be undone. All your data will be permanently deleted.\n\nType DELETE to confirm."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action est irréversible. Toutes vos données seront définitivement supprimées.\n\nTapez SUPPRIMER pour confirmer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta acción no se puede deshacer. Todos tus datos se eliminarán permanentemente.\n\nEscribe ELIMINAR para confirmar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Aktion kann nicht rückgängig gemacht werden. Alle deine Daten werden dauerhaft gelöscht.\n\nGib DELETE ein, um zu bestätigen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作は元に戻せません。すべてのデータは完全に削除されます。\n\n確認するにはDELETEと入力してください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это действие нельзя отменить. Все ваши данные будут безвозвратно удалены.\n\nВведите DELETE для подтверждения."
          }
        }
      }
    },
