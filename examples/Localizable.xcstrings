    "welcome_message": {
      "comment": "Greeting shown when user opens the app",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to the app!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenue dans l'application !"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Bienvenido a la app!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Willkommen in der App!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリへようこそ！"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добро пожаловать в приложение!"
          }
        }
      }
    },
