    "error_network": {
      "comment": "Shown when network request fails",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network error. Please check your connection and try again."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ошибка сети. Проверьте подключение и попробуйте снова."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de red. Por favor, comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Erreur réseau. Veuillez vérifier votre connexion et réessayer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Erro de rede. Verifique sua conexão e tente novamente."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de red. Por favor, revisa tu conexión e inténtalo de nuevo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Errore di rete. Controlla la tua connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークエラーです。接続を確認して、もう一度お試しください。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Błąd sieci. Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "no": {
          "stringUnit": {
            "state": "translated",
            "value": "Nettverksfeil. Vennligst sjekk tilkoblingen din og prøv igjen."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Netzwerkfehler. Bitte überprüfe deine Verbindung und versuche es erneut."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Netwerkfout. Controleer je verbinding en probeer het opnieuw."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 오류입니다. 연결 상태를 확인하고 다시 시도해 주세요."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Netværksfejl. Tjek venligst din forbindelse og prøv igen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nätverksfel. Kontrollera din anslutning och försök igen."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Eroare de rețea. Verifică-ți conexiunea și încearcă din nou."
          }
        }
      }
    },
