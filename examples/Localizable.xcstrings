{
  "sourceLanguage": "en",
  "strings": {
    "welcome_message": {
      "comment": "Greeting shown when user opens the app",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to the app!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добро пожаловать в приложение!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Bienvenido a la app!"
          }
        }
      }
    },
    "hello_user": {
      "comment": "Personalized greeting with username",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hello, %@!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Привет, %@!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Hola, %@!"
          }
        }
      }
    },
    "items_count": {
      "comment": "Shows number of items in cart",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have %d items in your cart"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В вашей корзине %d товаров"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes %d artículos en tu carrito"
          }
        }
      }
    },
    "settings_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройки"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustes"
          }
        }
      }
    },
    "logout_button": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log Out"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выйти"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerrar sesión"
          }
        }
      }
    },
    "error_network": {
      "comment": "Shown when network request fails",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network error. Please check your connection and try again."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ошибка сети. Проверьте подключение и попробуйте снова."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de red. Por favor, comprueba tu conexión e inténtalo de nuevo."
          }
        }
      }
    },
    "upload_progress": {
      "comment": "Shows upload progress percentage",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uploading... %.1f%% complete"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузка... %.1f%% завершено"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Subiendo... %.1f%% completado"
          }
        }
      }
    },
    "date_format": {
      "comment": "Date with day and month placeholders",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Created on %1$@ at %2$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создано %1$@ в %2$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Creado el %1$@ a las %2$@"
          }
        }
      }
    },
    "save_button": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save"
          }
        },
