    "This action cannot be undone. All your data will be permanently deleted.\n\nType DELETE to confirm.": {
      "comment": "An alert message displayed when a user attempts to delete their account. It explains that the action cannot be undone and asks the user to confirm by typing \"DELETE\".",
      "isCommentAutoGenerated": true,
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne handling kan ikke fortrydes. Alle dine data vil blive slettet permanent.\n\nSkriv DELETE for at bekræfte."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Aktion kann nicht rückgängig gemacht werden. Alle Ihre Daten werden dauerhaft gelöscht.\n\nGeben Sie DELETE ein, um zu bestätigen."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta acción no se puede deshacer. Todos tus datos se eliminarán permanentemente.\n\nEscribe ELIMINAR para confirmar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action est irréversible. Toutes vos données seront définitivement supprimées.\n\nTapez SUPPRIMER pour confirmer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione non può essere annullata. Tutti i tuoi dati verranno eliminati in modo permanente.\n\nDigita ELIMINA per confermare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作は元に戻せません。すべてのデータは永久に削除されます。\n\n確認するにはDELETEと入力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 작업은 되돌릴 수 없습니다. 모든 데이터가 영구적으로 삭제됩니다.\n\n확인하려면 DELETE를 입력하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne handlingen kan ikke angres. Alle dine data vil bli permanent slettet.\n\nSkriv DELETE for å bekrefte."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze actie kan niet ongedaan worden gemaakt. Al uw gegevens worden permanent verwijderd.\n\nTyp DELETE om te bevestigen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tej akcji nie można cofnąć. Wszystkie Twoje dane zostaną trwale usunięte.\n\nWpisz DELETE, aby potwierdzić."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta ação não pode ser desfeita. Todos os seus dados serão permanentemente excluídos.\n\nDigite EXCLUIR para confirmar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Această acțiune nu poate fi anulată. Toate datele tale vor fi șterse permanent.\n\nScrie DELETE pentru a confirma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это действие необратимо. Все ваши данные будут удалены навсегда.\n\nВведите DELETE для подтверждения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den här åtgärden kan inte ångras. Alla dina data kommer att raderas permanent.\n\nSkriv DELETE för att bekräfta."
          }
        },
        "no": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne handlingen kan ikke angres. Alle dine data vil bli permanent slettet.\n\nSkriv DELETE for å bekrefte."
          }
        }
      }
    },
